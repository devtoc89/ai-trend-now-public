{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/packages.json",
  "compilerOptions": {
    "declarationMap": true,
    "composite": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "#*": ["./src/*"]
    }
  },

  "include": ["src/**/*.ts"],
  "exclude": ["build", "dist", "**/*.d.ts"]
}

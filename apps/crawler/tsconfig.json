{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/packages.json",
  "compilerOptions": {
    "declarationMap": true,
    "composite": true,
    "baseUrl": "./src",
    "paths": {
      "#app/*": ["./app/*"],
      "#lib/*": ["./lib/*"],
      "#layer/*": ["./layer/*"],
      "#routes/*": ["./routes/*"]
    },
    "outDir": "./build",
    "rootDir": "."
  },

  "include": ["src/**/*.ts"],
  "exclude": ["build", "dist", "**/*.d.ts"]
}

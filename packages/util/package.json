{
  "name": "@repo/util",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js",
      "import": "./dist/src/index.js",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/src/*.d.ts",
      "require": "./dist/src/*.js",
      "import": "./dist/src/*.js",
      "default": "./src/*"
    },
    "./**/*": {
      "types": "./dist/src/**/*.d.ts",
      "require": "./dist/src/**/*.js",
      "import": "./dist/src/**/*.js",
      "default": "./src/**/*"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist&& tsc -p tsconfig.json"
  },
  "dependencies": {
    "clsx": "catalog:",
    "dayjs": "^1.11.13",
    "json5": "^2.2.3",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "@repo/typescript-config": "workspace:*",
    "rimraf": "catalog:"
  }
}

{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tailwind.config.ts", "index.ts", "s/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
